<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GLC PRESS CLUB · voices that inform, stories that inspire</title>
  <!-- Font Awesome 6 (free) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Beautiful Google Fonts: Playfair Display (elegant) + Inter (clean) + Poppins for buttons -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,700&family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: "Inter", sans-serif;
      background-color: #ffffff;
      color: #1e1e1e;
      line-height: 1.6;
      scroll-behavior: smooth;
    }

    :root {
      --black: #0a0a0a;
      --yellow: #f5c518;
      --white: #ffffff;
      --off-white: #f9f9f9;
      --gray-light: #eaeaea;
    }

    /* Beautiful typography */
    h1, h2, h3, h4, .logo-text, .slogan, .hero h1, .hero .slogan {
      font-family: "Playfair Display", serif;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .logo-text {
      font-family: "Playfair Display", serif;
      font-weight: 800;
      letter-spacing: 0.5px;
    }

    .btn, .nav-links a, .btn-submit, .role, .benefit-item, .card h3, .exec-card h4 {
      font-family: "Poppins", sans-serif;
      font-weight: 600;
    }

    .nav-links a {
      font-weight: 600;
      letter-spacing: 0.3px;
    }

    h2 {
      font-size: 2.5rem;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
      position: relative;
      display: inline-block;
      font-family: "Playfair Display", serif;
      font-weight: 700;
    }
    h2:after {
      content: '';
      display: block;
      width: 70px;
      height: 4px;
      background: var(--yellow);
      margin-top: 8px;
      border-radius: 3px;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 2rem 2rem;
    }

    /* navigation */
    .navbar {
      background: var(--black);
      color: var(--white);
      padding: 0.8rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .logo-container {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .logo-svg {
      width: 50px;
      height: 50px;
    }
    .logo-text {
      font-size: 1.6rem;
      letter-spacing: 0.5px;
      color: var(--white);
    }
    .logo-text span {
      color: var(--yellow);
    }
    .nav-links {
      display: flex;
      gap: 2.2rem;
      font-weight: 600;
    }
    .nav-links a {
      color: var(--white);
      text-decoration: none;
      font-size: 0.95rem;
      transition: 0.2s;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      font-weight: 600;
    }
    .nav-links a:hover {
      color: var(--yellow);
    }

    .btn {
      display: inline-block;
      background: var(--yellow);
      color: var(--black);
      padding: 0.8rem 2.2rem;
      border-radius: 40px;
      font-weight: 700;
      text-decoration: none;
      font-size: 1.1rem;
      border: 2px solid transparent;
      transition: 0.2s;
      box-shadow: 0 8px 16px rgba(245, 197, 24, 0.25);
      font-family: "Poppins", sans-serif;
      letter-spacing: 0.3px;
    }
    .btn:hover {
      background: var(--black);
      color: var(--yellow);
      border-color: var(--yellow);
    }

    /* HERO with BACKGROUND IMAGE */
    .hero {
      position: relative;
      min-height: 90vh;
      display: flex;
      align-items: center;
      color: var(--white);
      background: var(--black);
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1400&q=80');
      background-size: cover;
      background-position: center;
      opacity: 0.45;
      z-index: 0;
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 70%, rgba(0,0,0,0.7) 100%);
    }
    .hero .container {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.2rem;
      padding: 4rem 2rem;
    }
    .hero-logo {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .hero-logo svg {
      width: 100px;
      height: 100px;
      filter: drop-shadow(0 0 12px rgba(245,197,24,0.6));
    }
    .hero h1 {
      font-size: 4.5rem;
      line-height: 1.1;
      text-shadow: 0 4px 20px rgba(0,0,0,0.7);
      font-family: "Playfair Display", serif;
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    .hero h1 span {
      color: var(--yellow);
    }
    .hero .slogan {
      font-size: 1.8rem;
      font-weight: 400;
      color: var(--yellow);
      text-shadow: 0 2px 10px rgba(0,0,0,0.8);
      margin-top: 0.5rem;
      font-family: "Playfair Display", serif;
      font-style: italic;
      letter-spacing: 0.3px;
    }
    .hero p {
      font-size: 1.2rem;
      max-width: 650px;
      color: #f0f0f0;
      text-shadow: 0 2px 8px rgba(0,0,0,0.8);
      margin: 1rem 0 1.2rem;
      font-family: "Inter", sans-serif;
      font-weight: 300;
      letter-spacing: 0.2px;
    }

    /* sections */
    .section-white { background: var(--white); }
    .section-light { background: var(--off-white); }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }
    .card {
      background: var(--white);
      padding: 2rem 1.5rem;
      border-radius: 24px;
      border: 1px solid var(--gray-light);
      transition: 0.2s;
    }
    .card i {
      font-size: 2.5rem;
      color: var(--yellow);
      margin-bottom: 1rem;
    }
    .card h3 {
      font-size: 1.5rem;
      margin-bottom: 0.8rem;
      font-family: "Playfair Display", serif;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .card p {
      color: #3d3d3d;
      font-family: "Inter", sans-serif;
      font-weight: 400;
      line-height: 1.6;
    }
    .card:hover { transform: translateY(-6px); border-color: var(--yellow); }

    /* executives */
    .exec-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.8rem;
      margin: 2rem 0 1rem;
    }
    .exec-card {
      background: var(--white);
      padding: 1.6rem 1rem;
      border-radius: 28px;
      border: 1px solid var(--gray-light);
      text-align: center;
      transition: 0.15s;
    }
    .exec-card:hover { border-color: var(--yellow); transform: scale(1.01); }
    .exec-card i { font-size: 2.8rem; color: var(--yellow); margin-bottom: 0.8rem; }
    .exec-card h4 {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 0.2rem;
      font-family: "Playfair Display", serif;
      letter-spacing: -0.01em;
    }
    .exec-card .role {
      font-weight: 600;
      background: #f9f1d2;
      display: inline-block;
      padding: 0.2rem 1rem;
      border-radius: 40px;
      font-size: 0.8rem;
      margin-top: 0.5rem;
      font-family: "Poppins", sans-serif;
      letter-spacing: 0.3px;
      text-transform: uppercase;
    }
    .other-members {
      background: var(--yellow);
      border-radius: 60px;
      padding: 1.8rem 2rem;
      margin-top: 2rem;
      color: var(--black);
      font-weight: 600;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 2.5rem;
    }
    .other-members span {
      font-size: 1.2rem;
      background: rgba(0,0,0,0.03);
      padding: 0.3rem 1.2rem;
      border-radius: 40px;
      white-space: nowrap;
      font-family: "Inter", sans-serif;
      font-weight: 600;
      letter-spacing: 0.2px;
    }
    .other-members i { margin-right: 8px; }

    .benefits-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 2rem;
      margin: 2rem 0;
    }
    .benefit-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      background: var(--white);
      padding: 1.2rem 1.5rem;
      border-radius: 60px;
      border: 1px solid var(--gray-light);
      font-weight: 600;
      font-family: "Poppins", sans-serif;
      font-weight: 600;
      letter-spacing: 0.2px;
    }
    .benefit-item i { color: var(--yellow); font-size: 1.8rem; }

    .membership-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .info-card {
      background: var(--yellow);
      color: var(--black);
      padding: 2.5rem 2rem;
      border-radius: 32px;
    }
    .info-card h3 {
      font-family: "Playfair Display", serif;
      font-weight: 700;
      font-size: 2rem;
      letter-spacing: -0.01em;
    }
    .info-card p {
      font-size: 1.1rem;
      font-weight: 500;
      margin: 1rem 0;
      font-family: "Inter", sans-serif;
    }

    .contact-form {
      background: var(--white);
      padding: 2rem;
      border-radius: 32px;
      border: 1px solid var(--gray-light);
    }
    .contact-form h3 {
      font-family: "Playfair Display", serif;
      font-weight: 700;
      font-size: 1.8rem;
      margin-bottom: 1rem;
      letter-spacing: -0.01em;
    }
    .form-group { margin-bottom: 1.5rem; }
    input, textarea {
      width: 100%;
      padding: 1rem;
      border: 1px solid #ddd;
      border-radius: 40px;
      font-family: "Inter", sans-serif;
      font-size: 1rem;
      background: #fcfcfc;
      font-weight: 400;
    }
    textarea { border-radius: 30px; resize: vertical; }
    .btn-submit {
      background: var(--black);
      color: var(--white);
      border: none;
      padding: 1rem 2.5rem;
      border-radius: 40px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s;
      font-family: "Poppins", sans-serif;
      font-size: 1rem;
      letter-spacing: 0.3px;
    }
    .btn-submit:hover { background: var(--yellow); color: var(--black); }

    /* Contact section - updated fonts */
    .school-contact {
      margin-top: 0;
      font-size: 1.1rem;
    }
    .school-contact .contact-title {
      font-family: "Playfair Display", serif;
      font-weight: 700;
      font-size: 1.6rem;
      margin-top: 1rem;
      margin-bottom: 0.5rem;
      color: var(--black);
      letter-spacing: -0.01em;
    }
    .school-contact .contact-detail {
      font-family: "Inter", sans-serif;
      font-weight: 400;
      line-height: 1.8;
      color: #2d2d2d;
      font-size: 1.05rem;
    }
    .school-contact .contact-detail i {
      color: var(--yellow);
      width: 1.8rem;
      display: inline-block;
      font-size: 1.2rem;
    }
    .school-contact .contact-detail a {
      color: var(--black);
      text-decoration: none;
      transition: 0.2s;
    }
    .school-contact .contact-detail a:hover {
      color: var(--yellow);
    }

    .footer {
      background: var(--black);
      color: #aaa;
      text-align: center;
      padding: 2rem;
      font-size: 0.95rem;
      font-family: "Inter", sans-serif;
      font-weight: 300;
      letter-spacing: 0.3px;
    }
    .footer p:first-child {
      font-family: "Playfair Display", serif;
      font-weight: 400;
      font-style: italic;
      color: #ddd;
    }

    /* about paragraph */
    .about-text {
      font-size: 1.2rem;
      max-width: 900px;
      font-family: "Inter", sans-serif;
      font-weight: 400;
      line-height: 1.7;
      color: #2d2d2d;
    }

    /* uniform note */
    .uniform-note {
      margin-top: 1.5rem;
      font-style: italic;
      color: #4a4a4a;
      font-family: "Inter", sans-serif;
      font-weight: 400;
    }

    /* mobile */
    @media (max-width: 800px) {
      .navbar { flex-direction: column; gap: 0.8rem; }
      .nav-links { flex-wrap: wrap; justify-content: center; gap: 1.3rem; }
      .hero h1 { font-size: 2.8rem; }
      .hero .container { align-items: center; text-align: center; }
      .hero-logo { justify-content: center; }
      .hero p { max-width: 100%; }
      .membership-cards { grid-template-columns: 1fr; }
      h2 { font-size: 2rem; }
      .other-members { flex-direction: column; align-items: center; gap: 0.8rem; border-radius: 40px; }
      .hero .slogan { font-size: 1.3rem; }
      .contact-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</head>
