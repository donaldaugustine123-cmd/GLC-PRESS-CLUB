  <!-- HERO with background image -->
  <section id="home" class="hero">
    <div class="hero-bg"></div>
    <div class="container">
      <div class="hero-logo">
        <svg width="100" height="100" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="200,30 240,70 300,55 315,115 370,140 335,195 370,250 315,275 300,335 240,320 200,360 160,320 100,335 85,275 30,250 65,195 30,140 85,115 100,55 160,70" fill="black" stroke="#FFD700" stroke-width="6"/>
          <polygon points="40,180 360,180 330,210 360,240 40,240 70,210" fill="#FFD700"/>
          <text x="200" y="220" text-anchor="middle" font-size="34" font-weight="bold" fill="black" font-family="Arial, Helvetica, sans-serif">PRESS CLUB</text>
