  <!-- Benefits -->
  <section id="benefits" class="section-light">
    <div class="container">
      <h2>Why join?</h2>
      <div class="benefits-list">
        <div class="benefit-item"><i class="fas fa-check-circle"></i> Become a confident speaker</div>
        <div class="benefit-item"><i class="fas fa-check-circle"></i> Journalism & media skills</div>
        <div class="benefit-item"><i class="fas fa-check-circle"></i> Improve communication</div>
        <div class="benefit-item"><i class="fas fa-check-circle"></i> Leadership experience</div>
        <div class="benefit-item"><i class="fas fa-check-circle"></i> Teamwork & collaboration</div>
        <div class="benefit-item"><i class="fas fa-check-circle"></i> Real-world storytelling</div>
      </div>
    </div>
  </section>

  <!-- Membership -->
  <section id="membership" class="section-white">
    <div class="container">
      <h2>Membership</h2>
      <div class="membership-cards">
        <div class="info-card">
          <i class="fas fa-id-card" style="font-size: 3rem;"></i>
